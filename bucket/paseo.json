{
    "version": "0.1.94",
    "description": "One interface for Claude Code, Codex, Copilot, OpenCode, and Pi agents.",
    "homepage": "https://github.com/getpaseo/paseo",
    "license": "AGPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/getpaseo/paseo/releases/download/v0.1.94/Paseo-Setup-0.1.94-x64.zip",
            "hash": "fb596ea82344a0d0db1ee287694cf15b77c6fb731888e67e646b78ebd7198f63"
        },
        "arm64": {
            "url": "https://github.com/getpaseo/paseo/releases/download/v0.1.94/Paseo-Setup-0.1.94-arm64.zip",
            "hash": "916e9b4ed4e6ac295352550156da76d20bfb9376bd21178596eb226c7661daa0"
        }
    },
    "installer": {
        "script": [
            "Get-Process -Name 'Paseo' -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue",
            "if (!(Test-Path $persist_dir)) {",
            "    New-Item $persist_dir -Type Directory -Force | Out-Null",
            "}",
            "$runtimeCaches = @(",
            "    @{ Source = \"$env:APPDATA\\Paseo\"; Target = \"$persist_dir\\appdata\" },",
            "    @{ Source = \"$env:USERPROFILE\\.paseo\"; Target = \"$persist_dir\\.paseo\" }",
            ")",
            "foreach ($cache in $runtimeCaches) {",
            "    if (Test-Path $cache.Source) {",
            "        $sourceItem = Get-Item $cache.Source -Force",
            "        if (!(($sourceItem.Attributes -band [IO.FileAttributes]::ReparsePoint) -ne 0)) {",
            "            if (Test-Path $cache.Target) {",
            "                Copy-Item \"$($cache.Source)\\*\" $cache.Target -Recurse -Force -ErrorAction SilentlyContinue",
            "                try {",
            "                    Remove-Item $cache.Source -Force -Recurse -ErrorAction Stop",
            "                } catch {",
            "                    throw \"Failed to prepare persisted path '$($cache.Source)'. Close Paseo and retry. $($_.Exception.Message)\"",
            "                }",
            "            } else {",
            "                try {",
            "                    Move-Item $cache.Source $cache.Target -Force -ErrorAction Stop",
            "                } catch {",
            "                    throw \"Failed to migrate '$($cache.Source)' to '$($cache.Target)'. Close Paseo and retry. $($_.Exception.Message)\"",
            "                }",
            "            }",
            "        }",
            "    } elseif (!(Test-Path $cache.Target)) {",
            "        New-Item $cache.Target -Type Directory -Force | Out-Null",
            "    }",
            "    if (!(Test-Path $cache.Source)) {",
            "        New-Item -Type Junction -Path $cache.Source -Target $cache.Target | Out-Null",
            "    }",
            "}"
        ]
    },
    "uninstaller": {
        "script": [
            "Get-Process -Name 'Paseo' -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue",
            "$runtimeCaches = @(",
            "    @{ Source = \"$env:APPDATA\\Paseo\"; Target = \"$persist_dir\\appdata\" },",
            "    @{ Source = \"$env:USERPROFILE\\.paseo\"; Target = \"$persist_dir\\.paseo\" }",
            ")",
            "foreach ($cache in $runtimeCaches) {",
            "    if (Test-Path $cache.Source) {",
            "        $sourceItem = Get-Item $cache.Source -Force",
            "        if (($sourceItem.Attributes -band [IO.FileAttributes]::ReparsePoint) -ne 0) {",
            "            Remove-Item $cache.Source -Force -Recurse -ErrorAction SilentlyContinue",
            "        } elseif (!(Test-Path $cache.Target)) {",
            "            Move-Item $cache.Source $cache.Target -Force",
            "        } else {",
            "            Remove-Item $cache.Source -Force -Recurse -ErrorAction SilentlyContinue",
            "        }",
            "    }",
            "}"
        ]
    },
    "shortcuts": [
        [
            "Paseo.exe",
            "Paseo"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/getpaseo/paseo/releases/download/v$version/Paseo-Setup-$version-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/getpaseo/paseo/releases/download/v$version/Paseo-Setup-$version-arm64.zip"
            }
        }
    }
}
